{
  "name": "agent-session-replayer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.8",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "vite",
    "build": "bun run build:package && tsc -b && vite build",
    "build:package": "bun run --cwd packages/agent-session-replayer build",
    "pack:package": "bun run --cwd packages/agent-session-replayer pack",
    "typecheck": "tsc -b --pretty false",
    "test": "bun run build:package && vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "agent-session-replayer": "workspace:*",
    "motion": "^12.23.12",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
